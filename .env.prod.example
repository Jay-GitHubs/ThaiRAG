# ── ThaiRAG Production Environment Variables ──────────────────────────────────
# Copy this file to .env.prod and fill in all values marked CHANGE_ME.
# Never commit .env.prod to version control.
#
# Usage:
#   cp .env.prod.example .env.prod
#   # edit .env.prod
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d

# ── Domain ──────────────────────────────────────────────────────────────────
# The public hostname for TLS certificates and CORS.
DOMAIN=thairag.example.com

# ── Tier ────────────────────────────────────────────────────────────────────
# Options: free | standard | premium
THAIRAG_TIER=standard

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=thairag
POSTGRES_USER=thairag
# CHANGE_ME: use a strong random password (e.g. openssl rand -hex 32)
POSTGRES_PASSWORD=CHANGE_ME

# ── ThaiRAG — Database ───────────────────────────────────────────────────────
THAIRAG__DATABASE__URL=postgresql://thairag:CHANGE_ME@postgres:5432/thairag
THAIRAG__DATABASE__MAX_CONNECTIONS=20

# ── ThaiRAG — Auth ───────────────────────────────────────────────────────────
THAIRAG__AUTH__ENABLED=true
# CHANGE_ME: generate with `openssl rand -hex 64`
THAIRAG__AUTH__JWT_SECRET=CHANGE_ME
THAIRAG__AUTH__TOKEN_EXPIRY_HOURS=24

# Static API keys for OpenAI-compatible clients (comma-separated)
# Generate with: openssl rand -hex 24 | sed 's/^/sk-thairag-/'
THAIRAG__AUTH__API_KEYS=sk-thairag-CHANGE_ME

# ── ThaiRAG — Admin bootstrap ────────────────────────────────────────────────
# This account is seeded on first startup (ignored if already exists).
THAIRAG__ADMIN__EMAIL=admin@example.com
# CHANGE_ME: must satisfy password policy (min 8 chars, upper+lower+digit)
THAIRAG__ADMIN__PASSWORD=CHANGE_ME

# ── ThaiRAG — CORS ───────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Include your public URL.
THAIRAG__SERVER__CORS_ORIGINS=https://thairag.example.com

# ── LLM Provider ────────────────────────────────────────────────────────────
# Standard/Premium tier: Anthropic Claude
THAIRAG__PROVIDERS__LLM__KIND=claude
THAIRAG__PROVIDERS__LLM__MODEL=claude-3-5-haiku-20241022
# CHANGE_ME: your Anthropic API key
THAIRAG__PROVIDERS__LLM__API_KEY=sk-ant-CHANGE_ME

# Free tier alternative (Ollama on localhost, requires host network access):
#THAIRAG__PROVIDERS__LLM__KIND=ollama
#THAIRAG__PROVIDERS__LLM__MODEL=llama3.2
#THAIRAG__PROVIDERS__LLM__BASE_URL=http://host.docker.internal:11435

# ── Embedding Provider ───────────────────────────────────────────────────────
# Standard/Premium tier: OpenAI
THAIRAG__PROVIDERS__EMBEDDING__KIND=openai
THAIRAG__PROVIDERS__EMBEDDING__MODEL=text-embedding-3-small
THAIRAG__PROVIDERS__EMBEDDING__DIMENSION=1536
# CHANGE_ME: your OpenAI API key
THAIRAG__PROVIDERS__EMBEDDING__API_KEY=sk-CHANGE_ME

# Free tier alternative (FastEmbed, no API key needed):
#THAIRAG__PROVIDERS__EMBEDDING__KIND=fastembed
#THAIRAG__PROVIDERS__EMBEDDING__MODEL=BAAI/bge-small-en-v1.5
#THAIRAG__PROVIDERS__EMBEDDING__DIMENSION=384

# ── Vector Store (Qdrant) ────────────────────────────────────────────────────
THAIRAG__PROVIDERS__VECTOR_STORE__KIND=qdrant
THAIRAG__PROVIDERS__VECTOR_STORE__URL=http://qdrant:6334
THAIRAG__PROVIDERS__VECTOR_STORE__COLLECTION=thairag_chunks

# ── Reranker (optional — improves search quality) ────────────────────────────
# Standard/Premium tier: Cohere
#THAIRAG__PROVIDERS__RERANKER__KIND=cohere
#THAIRAG__PROVIDERS__RERANKER__MODEL=rerank-multilingual-v3.0
# CHANGE_ME if using Cohere:
#THAIRAG__PROVIDERS__RERANKER__API_KEY=CHANGE_ME

# ── Redis ────────────────────────────────────────────────────────────────────
THAIRAG__REDIS__URL=redis://redis:6379
THAIRAG__SESSION__BACKEND=redis
THAIRAG__EMBEDDING_CACHE__BACKEND=redis

# ── Tantivy full-text index path ─────────────────────────────────────────────
THAIRAG__PROVIDERS__TEXT_SEARCH__INDEX_PATH=/data/tantivy_index

# ── Grafana ──────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
# CHANGE_ME: strong password for Grafana dashboard access
GRAFANA_ADMIN_PASSWORD=CHANGE_ME

# ── OpenTelemetry (optional) ─────────────────────────────────────────────────
# Uncomment to enable OTLP tracing export.
#OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
#OTEL_SERVICE_NAME=thairag
