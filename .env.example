# ── PostgreSQL ────────────────────────────────────────────────────────
POSTGRES_DB=thairag
POSTGRES_USER=thairag
POSTGRES_PASSWORD=thairag

# ── ThaiRAG ──────────────────────────────────────────────────────────
# Tier: free | standard | premium
THAIRAG_TIER=free

# Database (Postgres or SQLite)
THAIRAG__DATABASE__URL=postgresql://thairag:thairag@postgres:5432/thairag
THAIRAG__DATABASE__MAX_CONNECTIONS=10
# To use SQLite instead: THAIRAG__DATABASE__URL=sqlite:///data/thairag.db

# Auth
THAIRAG__AUTH__ENABLED=true
THAIRAG__AUTH__JWT_SECRET=change-me-in-production-use-a-long-random-string
# Static API keys for external services (comma-separated)
# Used by Open WebUI and other OpenAI-compatible clients
#THAIRAG__AUTH__API_KEYS=sk-thairag-openwebui

# Open WebUI API key (shared between thairag and open-webui services)
THAIRAG_OPENWEBUI_API_KEY=sk-thairag-openwebui

# Super admin (seeded on startup)
THAIRAG__ADMIN__EMAIL=admin@thairag.local
THAIRAG__ADMIN__PASSWORD=Admin123

# ── LLM Provider ─────────────────────────────────────────────────────
# Free tier: Ollama (local)
THAIRAG__PROVIDERS__LLM__BASE_URL=http://host.docker.internal:11434
# Standard/Premium tier: Claude API
#THAIRAG__PROVIDERS__LLM__API_KEY=sk-ant-your-anthropic-key

# ── Embedding Provider ───────────────────────────────────────────────
# Free tier: Ollama or FastEmbed (local, no key needed)
# Standard/Premium tier: OpenAI
#THAIRAG__PROVIDERS__EMBEDDING__API_KEY=sk-your-openai-key

# ── Vector Store ─────────────────────────────────────────────────────
# Free tier: in-memory (no config needed)
# Standard/Premium tier: Qdrant
#THAIRAG__PROVIDERS__VECTOR_STORE__KIND=qdrant
#THAIRAG__PROVIDERS__VECTOR_STORE__URL=http://qdrant:6334
#THAIRAG__PROVIDERS__VECTOR_STORE__COLLECTION=thairag_chunks

# ── Reranker ─────────────────────────────────────────────────────────
# Standard/Premium tier: Cohere
#THAIRAG__PROVIDERS__RERANKER__API_KEY=your-cohere-key
