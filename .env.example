# ThaiRAG environment file. Copy to `.env` and edit.
#
#   cp .env.example .env
#
# Both compose files read this:
#   - docker-compose.yml            (local build)   loads it via `env_file: .env`
#   - docker-compose.registry.yml   (pre-built)     loads it via `env_file: .env`
# So any THAIRAG__… key set here is applied to the API container. Keys use the
# THAIRAG__ prefix with `__` (double underscore) as the nesting separator.

# ── PostgreSQL ────────────────────────────────────────────────────────
POSTGRES_DB=thairag
POSTGRES_USER=thairag
POSTGRES_PASSWORD=thairag

# ── Image selection (registry compose only) ──────────────────────────
# Tag to pull, and optional registry overrides (default: GHCR).
THAIRAG_TAG=latest
# THAIRAG_IMAGE=jdevspecialist/thairag
# THAIRAG_ADMIN_IMAGE=jdevspecialist/thairag-admin
# THAIRAG_CHAT_IMAGE=jdevspecialist/thairag-chat
# THAIRAG_OCR_IMAGE=jdevspecialist/thairag-paddleocr

# ── ThaiRAG ──────────────────────────────────────────────────────────
# Tier: free | standard | premium. Selects the baked-in config defaults;
# any key set below overrides that tier's default.
THAIRAG_TIER=standard

# Database (Postgres or SQLite). The registry compose constructs the Postgres
# URL from POSTGRES_* above, so you usually don't need to set this there.
THAIRAG__DATABASE__URL=postgresql://thairag:thairag@postgres:5432/thairag
THAIRAG__DATABASE__MAX_CONNECTIONS=10
# To use SQLite instead: THAIRAG__DATABASE__URL=sqlite:///data/thairag.db

# Auth
THAIRAG__AUTH__ENABLED=true
THAIRAG__AUTH__JWT_SECRET=change-me-in-production-use-a-long-random-string
# Static API key(s) for external OpenAI-compatible clients on /v1 (comma-separated).
# The compose stack wires THAIRAG_API_KEY into THAIRAG__AUTH__API_KEYS.
THAIRAG__AUTH__API_KEYS=sk-thairag-openwebui
THAIRAG_API_KEY=sk-thairag-openwebui

# Browser-reachable origins allowed by CORS (admin UI :8081 + chat-ui :8082)
THAIRAG__SERVER__CORS_ORIGINS=http://localhost:8081,http://localhost:8082

# Super admin (seeded on first startup)
THAIRAG__ADMIN__EMAIL=admin@thairag.local
THAIRAG__ADMIN__PASSWORD=Admin123

# Clickable citations (deploy-time, read at startup). Set to your PUBLIC,
# browser-reachable API origin so citation links resolve. Empty = opaque,
# non-URL citations.
#THAIRAG__CHAT_PIPELINE__CITATION_BASE_URL=https://api.yourco.com

# ┌───────────────────────────────────────────────────────────────────┐
# │ SELF-HOSTED GATEWAY (one OpenAI-compatible endpoint for everything)│
# │ For a server pointing LLM + embedding + reranker at a single        │
# │ gateway (e.g. https://llm.jay-tech-ai.com/v1): set each provider's  │
# │ KIND=open_ai_compatible and BASE_URL=<gateway>/v1 in the three      │
# │ sections below (uncomment + edit). Match the gateway's real model   │
# │ ids. The gateway must serve /v1/chat/completions, /v1/embeddings,   │
# │ and (for the reranker) /v1/rerank.                                  │
# └───────────────────────────────────────────────────────────────────┘

# ── LLM Provider ─────────────────────────────────────────────────────
# Kind: ollama | open_ai_compatible | anthropic | openai
# Free tier: Ollama (local). Standard/premium: a hosted or gateway endpoint.
#THAIRAG__PROVIDERS__LLM__KIND=open_ai_compatible
THAIRAG__PROVIDERS__LLM__BASE_URL=http://host.docker.internal:11435
#THAIRAG__PROVIDERS__LLM__MODEL=qwen3.6-27b-fast
#THAIRAG__PROVIDERS__LLM__API_KEY=sk-...
# Gateway example: BASE_URL=https://llm.jay-tech-ai.com/v1 + KIND/MODEL/API_KEY above.

# ── Embedding Provider ───────────────────────────────────────────────
# Free tier: Ollama or FastEmbed (local, no key). Switching the embedding
# model/dimension requires re-ingesting (it wipes the vector collection).
#THAIRAG__PROVIDERS__EMBEDDING__KIND=open_ai_compatible
#THAIRAG__PROVIDERS__EMBEDDING__BASE_URL=http://host.docker.internal:11435
#THAIRAG__PROVIDERS__EMBEDDING__MODEL=qwen3-embedding:0.6b
#THAIRAG__PROVIDERS__EMBEDDING__DIMENSION=1024
#THAIRAG__PROVIDERS__EMBEDDING__API_KEY=sk-...

# ── Vector Store ─────────────────────────────────────────────────────
# Free tier: in-memory. Standard/premium: Qdrant (the compose `qdrant` service).
# The registry compose forces the in-cluster Qdrant URL; only set these to
# point elsewhere.
#THAIRAG__PROVIDERS__VECTOR_STORE__KIND=qdrant
#THAIRAG__PROVIDERS__VECTOR_STORE__URL=http://qdrant:6334
#THAIRAG__PROVIDERS__VECTOR_STORE__COLLECTION=thairag_chunks

# ── Reranker ─────────────────────────────────────────────────────────
# Kind: passthrough (off) | cohere | jina. The `jina` kind is a generic
# Jina-protocol /v1/rerank client — point base_url at any compatible endpoint,
# including a self-hosted/gateway cross-encoder like rerank-bge.
# base_url + normalize_scores apply to the jina kind only; set
# normalize_scores=true for raw cross-encoder logits (e.g. rerank-bge) or the
# relevance gate misreads their unbounded scores. (Also settable in the admin UI:
# Settings → Providers → Reranker.)
#   Cohere (cloud):
#THAIRAG__PROVIDERS__RERANKER__KIND=cohere
#THAIRAG__PROVIDERS__RERANKER__MODEL=rerank-v3.5
#THAIRAG__PROVIDERS__RERANKER__API_KEY=your-cohere-key
#   Gateway cross-encoder (Jina protocol → calls <base_url>/v1/rerank):
#THAIRAG__PROVIDERS__RERANKER__KIND=jina
#THAIRAG__PROVIDERS__RERANKER__MODEL=rerank-bge
#THAIRAG__PROVIDERS__RERANKER__BASE_URL=https://llm.jay-tech-ai.com/v1
#THAIRAG__PROVIDERS__RERANKER__API_KEY=sk-your-gateway-key
#THAIRAG__PROVIDERS__RERANKER__NORMALIZE_SCORES=true

# ── Document processing: vision & deterministic OCR ──────────────────
# Describe images / OCR scanned & garbled PDF pages with a vision LLM.
#THAIRAG__DOCUMENT__IMAGE_DESCRIPTION_ENABLED=true
# Deterministic Thai OCR tier (PaddleOCR sidecar). TWO things are required, or
# the sidecar simply won't exist / won't be used:
#   1. Activate the `ocr` Compose profile (it's off by default). Profile-gated
#      services are skipped by EVERY compose command — `pull` AND `up` — unless
#      the profile is active, so either pass --profile ocr each time:
#        docker compose -f docker-compose.registry.yml --profile ocr pull
#        docker compose -f docker-compose.registry.yml --profile ocr up -d
#      …or set it once here so plain pull/up/ps include paddle automatically:
#COMPOSE_PROFILES=ocr
#   2. Uncomment this so the backend routes OCR-needing pages to it (local,
#      no hallucination) instead of the vision LLM:
#THAIRAG__DOCUMENT__OCR_SIDECAR_URL=http://paddleocr:8086
# Per-page vision/OCR concurrency (default 2).
#THAIRAG__DOCUMENT__PDF_VISION_CONCURRENCY=2
# Note: per-document handling modes (Auto / High quality / OCR only / Text only),
# the pre-ingest preview, and the Pipeline "Extraction" line are built into the
# image — they need no env config. Provider/model/OCR settings can also be set
# at runtime in the admin UI (Settings → persisted in Postgres, hot-reload).

# ── Redis (optional, for multi-instance scaling) ─────────────────────
#THAIRAG__REDIS__URL=redis://redis:6379
#THAIRAG__SESSION__BACKEND=redis
#THAIRAG__EMBEDDING_CACHE__BACKEND=redis

# ── OpenTelemetry (optional) ─────────────────────────────────────────
#OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
#OTEL_SERVICE_NAME=thairag
